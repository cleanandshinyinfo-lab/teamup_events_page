# PostgreSQL Connection (Supabase Transaction Pooler)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# n8n webhook URL para notificaciones de invitación aceptada
N8N_SLACK_WEBHOOK_URL=https://n8n.tu-dominio.com/webhook/invitacion-aceptada

# Slack Incoming Webhook del canal donde llegan los avisos de invitación aceptada/asignada
SLACK_WEBHOOK_INVITATIONS=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Slack Bot Token (xoxb-...) usado para chat.postMessage
# (Fase B: el cleaner acepta el servicio cancelado pero proponiendo otro horario)
SLACK_BOT_TOKEN=xoxb-...
# Channel ID destino del aviso "otro horario".
# Pruebas: canal de test. Producción: el ID de #servicio-al-cliente.
SLACK_SERVICIO_AL_CLIENTE_CHANNEL_ID=C0XXXXXXXXX
# Channel ID de #cancelacion-de-ultimo-minuto (donde Zapier publica las cancelaciones).
# Al aceptarse un servicio desde /servicios se responde en el hilo del mensaje de Zapier.
# El bot debe estar invitado al canal y tener el scope groups:history.
SLACK_CANCELACION_CHANNEL_ID=C08JAKWVAQ6
# Channel ID de #servicios-agendados-desde-la-app (declinados aceptados en horario original).
SLACK_AGENDADOS_CHANNEL_ID=C0A7HGG256Z

# Aviso a la clienta (QUO + correo) cuando una cleaner acepta en horario original.
# QUO via OpenPhone (mismo API key que los rappels):
OPENPHONE_API_KEY=
# Correo via email-proxy (mismo contenedor que los rappels):
EMAIL_PROXY_URL=https://email-proxy.srv1035704.hstgr.cloud
EMAIL_PROXY_SECRET=
# MODO PRUEBA del aviso al cliente: si tienen valor, QUO/correo van a estos destinos
# (no al cliente real). Vaciar en producción.
CLIENT_NOTIFY_TEST_PHONE=
CLIENT_NOTIFY_TEST_EMAIL=

# Interruptor de la bolsa: 'on' para activar la página /servicios; cualquier otro valor = pausa.
BOLSA_DISPONIBLE=on

# Rappel (§8) disparado al aceptar un servicio de la bolsa cuando estamos en Escenario 2
# (el rappel de 9am de ESE servicio ya pasó sin cubrirlo). Reusa OPENPHONE_API_KEY /
# EMAIL_PROXY_URL / EMAIL_PROXY_SECRET de arriba (mismos proveedores que el rappel
# automático de service-reminders y que el aviso de "equipo de reemplazo").
#
# COMPUERTA DE SEGURIDAD: por defecto (ausente o cualquier valor distinto de 'false'),
# el rappel corre en MODO PRUEBA: ningún SMS/correo llega al cliente real, se redirige a
# RAPPEL_TEST_PHONE / RAPPEL_TEST_EMAIL. Sin destino de prueba configurado, ese canal
# simplemente no se manda (solo se loguea). Solo RAPPEL_TEST_MODE=false explícito manda
# a clientes reales — cambiar con cuidado y solo en producción cuando esté validado.
RAPPEL_TEST_MODE=true
RAPPEL_TEST_PHONE=
RAPPEL_TEST_EMAIL=

# --- /bolsa: recorte por distancia (coincidencia total con el cron de 6pm) ---
# Con esta URL configurada, /bolsa llama a services-by-distance-api (misma que el
# cron) para recortar a <=90 min de viaje + ventana mañana/pasado mañana, y muestra
# EXACTAMENTE lo que llegó por WhatsApp. Sin ella (o si la API falla), /bolsa cae al
# RPC directo: muestra el pool completo que cumple las reglas por cleaner, sin el
# recorte de distancia/ventana. La distance-api debe estar redeployada con
# get_bolsa_contracts en su SUPABASE_RPC_ALLOWLIST para que el override rpc_name aplique.
SERVICES_BY_DISTANCE_API_URL=
# RPC que la página le pide a la distance-api (default get_bolsa_contracts).
BOLSA_DISTANCE_RPC_NAME=get_bolsa_contracts
# TZ de referencia para la ventana mañana/pasado (mismo default que el cron: America/Toronto).
BOLSA_BUCKET_TIMEZONE=America/Toronto
